<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title><%= tarefa.titulo %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <a href="/pagina/tarefas">← Voltar</a>
  <h1><%= tarefa.titulo %></h1>

  <p><strong>Descrição:</strong> <%= tarefa.descricao || "Sem descrição" %></p>
  <p><strong>Prioridade:</strong> <%= tarefa.prioridade %></p>
  <p><strong>Status:</strong> <%= tarefa.concluida ? "Concluída" : "Pendente" %></p>
  <p><strong>Criada em:</strong> <%= new Date(tarefa.dataCriacao).toLocaleString("pt-BR") %></p>

  <form action="/tarefas/<%= tarefa.id %>/concluir" method="POST">
    <button type="submit"><%= tarefa.concluida ? "Reabrir" : "Concluir" %></button>
  </form>

  <form action="/tarefas/<%= tarefa.id %>/excluir" method="POST">
    <button type="submit">Excluir</button>
  </form>
</body>
</html>